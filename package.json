{
  "name": "superette-plus",
  "version": "1.0.0",
  "description": "Supérette Plus — Premium POS for Algerian minimarkets",
  "main": "src/main.js",
  "author": "Vemo068",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable",
    "build:installer": "electron-builder --win nsis"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "lowdb": "^1.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.vemo068.superetteplus",
    "productName": "Supérette Plus",
    "copyright": "Copyright © 2026 Vemo068",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Supérette Plus",
      "installerLanguages": ["fr_FR", "en_US"]
    },
    "portable": {
      "artifactName": "SuperettePlus-Portable-${version}.exe"
    }
  }
}
